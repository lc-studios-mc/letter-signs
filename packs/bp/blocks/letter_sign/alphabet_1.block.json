					"h": "q.block_state('lettersigns:letter') == 'h'",
					"i": "q.block_state('lettersigns:letter') == 'i'",
					"j": "q.block_state('lettersigns:letter') == 'j'",
					"k": "q.block_state('lettersigns:letter') == 'k'",
					"l": "q.block_state('lettersigns:letter') == 'l'",
					"m": "q.block_state('lettersigns:letter') == 'm'",
					"n": "q.block_state('lettersigns:letter') == 'n'",
					"o": "q.block_state('lettersigns:letter') == 'o'",
