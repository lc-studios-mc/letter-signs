{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "lettersigns:letter_sign_alphabet_2",
			"menu_category": {
				"category": "none"
			},
			"states": {
				"lettersigns:direction": ["north", "east", "south", "west"],
				"lettersigns:tilt": ["none", "up", "down"],
				"lettersigns:letter": ["q", "r", "s", "t", "u", "v", "w", "x", "y", "z"],
				"lettersigns:color": ["black", "gray", "white"]
			}
		},
		"components": {
			"minecraft:loot": "loot_tables/lettersigns/letter_sign/white.json",
			"minecraft:geometry": {
				"identifier": "geometry.lettersigns.letter_sign.alphabet",
				"bone_visibility": {
					"a": false,
					"b": false,
					"c": false,
					"d": false,
					"e": false,
					"f": false,
					"g": false,
					"h": false,
					"i": false,
					"j": false,
					"k": false,
					"l": false,
					"m": false,
					"n": false,
					"o": false,
					"p": false,
					"q": "q.block_state('lettersigns:letter') == 'q'",
					"r": "q.block_state('lettersigns:letter') == 'r'",
					"s": "q.block_state('lettersigns:letter') == 's'",
					"t": "q.block_state('lettersigns:letter') == 't'",
					"u": "q.block_state('lettersigns:letter') == 'u'",
					"v": "q.block_state('lettersigns:letter') == 'v'",
					"w": "q.block_state('lettersigns:letter') == 'w'",
					"x": "q.block_state('lettersigns:letter') == 'x'",
					"y": "q.block_state('lettersigns:letter') == 'y'",
					"z": "q.block_state('lettersigns:letter') == 'z'"
				}
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "lettersigns:letter_sign.white",
					"render_method": "alpha_test"
				}
			},
			"minecraft:destruction_particles": {
				"texture": "white_concrete",
				"particle_count": 30
			},
			"minecraft:light_dampening": 0,
			"minecraft:collision_box": false,
			"minecraft:selection_box": {
				"origin": [-8, 0, 7],
				"size": [16, 16, 1]
			},
			"minecraft:destructible_by_explosion": {
				"explosion_resistance": 5
			},
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 0.15
			},
			"tag:lettersigns:letter_sign": {}
		},
		"permutations": [
			{
				"condition": "q.block_state('lettersigns:color') == 'black'",
				"components": {
					"minecraft:loot": "loot_tables/lettersigns/letter_sign/black.json",
					"minecraft:material_instances": {
						"*": {
							"texture": "lettersigns:letter_sign.black",
							"render_method": "alpha_test"
						}
					},
					"minecraft:destruction_particles": {
						"texture": "black_concrete",
						"particle_count": 30
					}
				}
			},
			{
				"condition": "q.block_state('lettersigns:color') == 'gray'",
				"components": {
					"minecraft:loot": "loot_tables/lettersigns/letter_sign/gray.json",
					"minecraft:material_instances": {
						"*": {
							"texture": "lettersigns:letter_sign.gray",
							"render_method": "alpha_test"
						}
					},
					"minecraft:destruction_particles": {
						"texture": "light_gray_concrete",
						"particle_count": 30
					}
				}
			},

			{
				"condition": "q.block_state('lettersigns:direction') == 'north'",
				"components": {
					"minecraft:transformation": { "rotation": [0, 0, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:direction') == 'east'",
				"components": {
					"minecraft:transformation": { "rotation": [0, -90, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:direction') == 'south'",
				"components": {
					"minecraft:transformation": { "rotation": [0, 180, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:direction') == 'west'",
				"components": {
					"minecraft:transformation": { "rotation": [0, 90, 0] }
				}
			},

			{
				"condition": "q.block_state('lettersigns:tilt') == 'down' && q.block_state('lettersigns:direction') == 'north'",
				"components": {
					"minecraft:transformation": { "rotation": [-90, 0, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:tilt') == 'down' && q.block_state('lettersigns:direction') == 'east'",
				"components": {
					"minecraft:transformation": { "rotation": [-90, -90, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:tilt') == 'down' && q.block_state('lettersigns:direction') == 'south'",
				"components": {
					"minecraft:transformation": { "rotation": [-90, 180, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:tilt') == 'down' && q.block_state('lettersigns:direction') == 'west'",
				"components": {
					"minecraft:transformation": { "rotation": [-90, 90, 0] }
				}
			},

			{
				"condition": "q.block_state('lettersigns:tilt') == 'up' && q.block_state('lettersigns:direction') == 'north'",
				"components": {
					"minecraft:transformation": { "rotation": [90, 0, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:tilt') == 'up' && q.block_state('lettersigns:direction') == 'east'",
				"components": {
					"minecraft:transformation": { "rotation": [90, -90, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:tilt') == 'up' && q.block_state('lettersigns:direction') == 'south'",
				"components": {
					"minecraft:transformation": { "rotation": [90, 180, 0] }
				}
			},
			{
				"condition": "q.block_state('lettersigns:tilt') == 'up' && q.block_state('lettersigns:direction') == 'west'",
				"components": {
					"minecraft:transformation": { "rotation": [90, 90, 0] }
				}
			}
		]
	}
}
