{
	"compilerOptions": {
		"rootDir": "./scripts",
		"target": "es2023",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"moduleDetection": "force",
		"types": [],
		"lib": ["es2023"],
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": true
	},
	"include": ["./scripts/**/*"]
}
